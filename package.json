{
  "name": "customizer",
  "private": true,
  "version": "0.0.10",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000 --host --open dev-index.html",
    "prebuild": "npx @inlang/paraglide-js compile",
    "build": "npm run prebuild && vue-tsc -b && vite build",
    "build:staging": "npm run prebuild && vue-tsc -b && vite build --mode staging",
    "build:production": "npm run prebuild && vue-tsc -b && vite build --mode production && node scripts/minify-dist.mjs",
    "preview": "vite preview --port 3000 --host --open index.html",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "npm run prebuild && vue-tsc --b",
    "dev:with-paraglide": "npm run prebuild && npm run dev",
    "machine-translate": "inlang machine translate --project project.inlang",
    "prepare": "husky"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "fabric": "^6.7.1",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.544.0",
    "opentype.js": "^1.3.4",
    "pinia": "^3.0.4",
    "posthog-js": "^1.310.1",
    "reka-ui": "^2.6.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.180.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "vue-sonner": "^2.0.9",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@iconify-json/radix-icons": "^1.2.5",
    "@iconify/vue": "^5.0.0",
    "@inlang/cli": "^3.0.12",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.7.0",
    "@types/opentype.js": "^1.3.9",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "unplugin-icons": "^22.4.2",
    "unplugin-vue-components": "^29.1.0",
    "vite": "^7.1.9",
    "vue-tsc": "^3.1.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  }
}
