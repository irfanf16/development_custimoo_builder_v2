{
  "name": "customizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000 --host --open dev-index.html",
    "prebuild": "npx @inlang/paraglide-js compile",
    "build": "npm run prebuild && vue-tsc -b && vite build",
    "build:staging": "npm run prebuild && vue-tsc -b && vite build --mode staging",
    "preview": "vite preview --port 3001 --host --open index.html",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "npm run prebuild && vue-tsc --noEmit",
    "dev:with-paraglide": "npm run prebuild && npm run dev",
    "machine-translate": "inlang machine translate --project project.inlang",
    "prepare": "husky"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.2.0",
    "@tailwindcss/vite": "^4.1.11",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fabric": "^6.7.1",
    "lucide-vue-next": "^0.534.0",
    "pinia": "^3.0.3",
    "reka-ui": "^2.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.179.1",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@inlang/cli": "^3.0.0",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "lint-staged": "^15.2.10",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "unplugin-icons": "^22.2.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.1.3",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  }
}
